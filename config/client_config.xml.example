<?xml version="1.0" encoding="UTF-8"?>
<!--
  复制为 client_config.xml 后按本机修改。
  loginHost：可访问的 LoginServer IP（虚拟机/局域网地址因机器而异）
-->
<ClientConfig>
    <windowWidth>1280</windowWidth>
    <windowHeight>720</windowHeight>
    <logLevel>info</logLevel>
    <logToConsole>false</logToConsole>
    <loginHost>127.0.0.1</loginHost>
    <loginPort>9010</loginPort>
    <!-- 可选：覆盖服务端 S2C_GATEWAY_INFO 下发的 IP -->
    <!-- <gatewayHost>192.168.1.100</gatewayHost> -->
    <!-- Login/Gateway 同机且服务端 IP 过期时设为 1 -->
    <!-- <gatewayUseLoginHost>1</gatewayUseLoginHost> -->
    <!-- 网络时序（毫秒）；联调时可适当缩短以便快速发现超时 -->
    <connectTimeoutMs>10000</connectTimeoutMs>
    <responseTimeoutMs>15000</responseTimeoutMs>
    <zoneListResponseTimeoutMs>10000</zoneListResponseTimeoutMs>
    <heartbeatIntervalMs>10000</heartbeatIntervalMs>
    <moveSendIntervalMs>100</moveSendIntervalMs>
    <moveMinDelta>0.01</moveMinDelta>
    <maxFlushBytesPerPoll>16384</maxFlushBytesPerPoll>
    <logoutTimeoutMs>15000</logoutTimeoutMs>
    <!-- 地图 CDN（开发期本地 serve_map_cdn.ps1 默认端口 8765） -->
    <!-- <mapCdnBaseUrl>http://127.0.0.1:8765/rpg/map/</mapCdnBaseUrl> -->
    <!-- <addressablesRemoteUrl>http://127.0.0.1:8765/rpg/map/addressables/StandaloneWindows64/catalog_1.0.json</addressablesRemoteUrl> -->
    <Tls enabled="1" ca="config/tls/ca.crt" insecureSkipVerify="0" minVersion="1.2"/>
</ClientConfig>
